project     = "perfect-cat"
environment = "dev"
region      = "ap-northeast-1"

# Set after first `terraform apply` (which creates ECR), then build & push images, then re-apply.
# Format: <acct>.dkr.ecr.<region>.amazonaws.com/<repo>:<tag>
backend_image  = "REPLACE_ME.dkr.ecr.ap-northeast-1.amazonaws.com/perfect-cat-dev-backend:latest"
frontend_image = "REPLACE_ME.dkr.ecr.ap-northeast-1.amazonaws.com/perfect-cat-dev-frontend:latest"

# Sizing (ffmpeg is CPU-bound; bump backend if transcoding is slow)
backend_cpu    = 1024
backend_memory = 2048

backend_desired_count  = 1
frontend_desired_count = 1

# Optional HTTPS + custom domain (leave blank for HTTP-only via ALB DNS name).
# If you registered the domain in Route53 (Registered domains → Register domain),
# just set domain_name below — Terraform creates and DNS-validates the ACM certs
# (ALB + CloudFront/us-east-1) and the Route53 alias records automatically:
#   apex   <domain>        → ALB (frontend + /api/*)
#   www.<domain>           → ALB
#   media.<domain>         → CloudFront (HLS)
# domain_name = "example.com"
#
# Only set these to bring your OWN pre-issued certs (skips auto-creation):
# acm_certificate_arn_alb        = "arn:aws:acm:ap-northeast-1:123456789012:certificate/..."
# acm_certificate_arn_cloudfront = "arn:aws:acm:us-east-1:123456789012:certificate/..."

# Optional New Relic APM (leave blank to ship the backend with the agent
# disabled — no data leaves the task).
# Prefer to pass via TF_VAR_new_relic_license_key in the environment so it
# doesn't get committed.
# new_relic_license_key = "abcdef0123456789abcdef0123456789abcdNRAL"
# new_relic_app_name    = "perfect-cat-streaming-backend"

# Optional New Relic ALERTS via the terraform-provider-newrelic. Requires a User
# key (NRAK-*); with it unset, all alert resources are skipped (count = 0).
# Put the secret bits in the gitignored secret.auto.tfvars instead of here.
# new_relic_account_id   = 1234567               # default 6729598
# new_relic_user_api_key = "NRAK-xxxxxxxxxxxxxx" # required to manage alerts
# new_relic_region       = "US"                  # or "EU"
# new_relic_alert_email  = "you@example.com"      # empty = no email workflow
