# --- Backend ---
APP_PORT=8080
STORAGE_UPLOAD_DIR=/var/app/data/uploads
STORAGE_HLS_DIR=/var/app/data/hls
PUBLIC_BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
FFMPEG_BIN=ffmpeg

# --- S3 publisher (set in production / ECS task) ---
# When S3_BUCKET is non-empty, the transcoder uploads HLS to S3 after each job
# and stores the CloudFront playlist URL on the Video. Leave blank for local
# mode (default).
S3_BUCKET=
S3_HLS_PREFIX=hls
S3_REGION=
# Public CDN base, e.g. https://d1234.cloudfront.net (no trailing slash)
MEDIA_BASE_URL=

# --- Local ephemeral-disk janitor (S3 mode only) ---
# In S3 mode the local upload/HLS files are redundant after publish. A periodic
# sweep deletes anything older than the TTL so Fargate's ephemeral disk doesn't
# fill up. Runs only when S3_BUCKET is set; never deletes in local mode.
LOCAL_CLEANUP_DISABLED=false
LOCAL_CLEANUP_TTL_HOURS=24
LOCAL_CLEANUP_INTERVAL_HOURS=24

# --- Database (MySQL on RDS in production, mysql:8.4 container locally) ---
# When set, the backend uses MySQL for metadata. Empty = in-memory + JSON.
# URL form (recommended): mysql://user:pass@host:3306/dbname?parseTime=true[&tls=skip-verify]
# Driver DSN form is also accepted as-is.
DATABASE_URL=mysql://perfectcat:perfectcat@db:3306/perfectcat?parseTime=true

# Local MySQL container credentials (used by docker-compose's db service)
MYSQL_DATABASE=perfectcat
MYSQL_USER=perfectcat
MYSQL_PASSWORD=perfectcat
MYSQL_ROOT_PASSWORD=rootpw

# --- New Relic APM (Go agent in backend) ---
# Leave NEW_RELIC_LICENSE_KEY empty for a no-op (disabled) agent — useful in dev
# when you don't want to ship data. Set it to enable tracing of:
#   - HTTP transactions (chi route patterns)
#   - MySQL queries (datastore segments via nrmysql)
#   - AWS S3 calls (external segments via nrawssdk-v2)
#   - Background ffmpeg/ffprobe jobs (transcoder.job)
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=PerfectCatStreaming
# debug | info | (empty = warn)
NEW_RELIC_LOG_LEVEL=
# dev | stg | prod — appended to the app name for non-prod environments
APP_ENV=dev

# AI monitoring (optional; recommended by NR's Go install flow when the app
# calls LLMs). Off by default to avoid bloating event volume.
NEW_RELIC_AI_MONITORING_ENABLED=false
NEW_RELIC_CUSTOM_INSIGHTS_EVENTS_MAX_SAMPLES_STORED=10000
NEW_RELIC_AI_MONITORING_STREAMING_ENABLED=false

# --- New Relic User key (NRAK-*) ---
# NOT used by the Go agent itself. This is the personal API key used for
# management APIs (NerdGraph) — e.g. provisioning NR dashboards/alerts via
# the official terraform-provider-newrelic. Keep blank unless you use it.
NEW_RELIC_USER_API_KEY=

# --- Chaos engineering (optional; for NR troubleshooting practice) ---
# Off by default. Flip CHAOS_ENABLED=true to inject synthetic perf
# degradation labelled in NR with chaos.* attributes / "chaos.delay" segment.
CHAOS_ENABLED=false
# HTTP latency spike: every PERIOD seconds open a WINDOW where CHANCE% of
# requests get a uniform delay in [MIN, MAX] ms.
CHAOS_PERIOD_SEC=300
CHAOS_WINDOW_SEC=60
CHAOS_LATENCY_CHANCE_PERCENT=40
CHAOS_LATENCY_MIN_MS=500
CHAOS_LATENCY_MAX_MS=2000
# HTTP error injection (independent of latency window). 0 = off.
CHAOS_ERROR_CHANCE_PERCENT=0
# DB pool contention: every PERIOD seconds, fire CONCURRENCY parallel
# SELECT SLEEP(SEC) queries. 0 = off.
CHAOS_DB_SLOW_PERIOD_SEC=0
CHAOS_DB_SLOW_QUERY_SEC=5
CHAOS_DB_SLOW_CONCURRENCY=3

# --- Compose host-side ---
# Where the host machine stores cat clips. Override on servers (e.g. /srv/perfect-cat/data).
HOST_DATA_DIR=./data

# --- Frontend (build-time) ---
VITE_API_BASE_URL=http://localhost:8080
# New Relic Browser Agent + Video Agent. All five must be set for the Browser
# Agent to initialise; leave any blank to ship the bundle with NR disabled.
# Values come from the New Relic UI > Browser application "Snippet" page.
VITE_NEW_RELIC_LICENSE_KEY=
VITE_NEW_RELIC_APP_ID=
VITE_NEW_RELIC_ACCOUNT_ID=
VITE_NEW_RELIC_TRUST_KEY=
VITE_NEW_RELIC_AGENT_ID=
