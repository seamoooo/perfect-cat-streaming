# --- Backend ---
APP_PORT=8080
STORAGE_UPLOAD_DIR=/var/app/data/uploads
STORAGE_HLS_DIR=/var/app/data/hls
PUBLIC_BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
FFMPEG_BIN=ffmpeg

# --- S3 publisher (set in production / ECS task) ---
# When S3_BUCKET is non-empty, the transcoder uploads HLS to S3 after each job
# and stores the CloudFront playlist URL on the Video. Leave blank for local
# mode (default).
S3_BUCKET=
S3_HLS_PREFIX=hls
S3_REGION=
# Public CDN base, e.g. https://d1234.cloudfront.net (no trailing slash)
MEDIA_BASE_URL=

# --- Database (MySQL on RDS in production, mysql:8.4 container locally) ---
# When set, the backend uses MySQL for metadata. Empty = in-memory + JSON.
# URL form (recommended): mysql://user:pass@host:3306/dbname?parseTime=true[&tls=skip-verify]
# Driver DSN form is also accepted as-is.
DATABASE_URL=mysql://perfectcat:perfectcat@db:3306/perfectcat?parseTime=true

# Local MySQL container credentials (used by docker-compose's db service)
MYSQL_DATABASE=perfectcat
MYSQL_USER=perfectcat
MYSQL_PASSWORD=perfectcat
MYSQL_ROOT_PASSWORD=rootpw

# --- Compose host-side ---
# Where the host machine stores cat clips. Override on servers (e.g. /srv/perfect-cat/data).
HOST_DATA_DIR=./data

# --- Frontend (build-time) ---
VITE_API_BASE_URL=http://localhost:8080
# Leave empty in dev to use the ConsoleKanpachiSink. In prod, fill these to enable New Relic Browser.
VITE_NEW_RELIC_LICENSE_KEY=
VITE_NEW_RELIC_APP_ID=
