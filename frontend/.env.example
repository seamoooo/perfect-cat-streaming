VITE_API_BASE_URL=http://localhost:8080

# New Relic Browser Agent + Video Agent. All five must be set to enable; any
# blank value disables the agent at build time and ships a no-op bundle.
VITE_NEW_RELIC_LICENSE_KEY=
VITE_NEW_RELIC_APP_ID=
VITE_NEW_RELIC_ACCOUNT_ID=
VITE_NEW_RELIC_TRUST_KEY=
VITE_NEW_RELIC_AGENT_ID=
# NR Video Agent application ID (own entity, not the Browser app ID).
# Get from NR UI > Streaming Video & Ads > app settings.
VITE_NEW_RELIC_VIDEO_APP_ID=

# Player chaos: fraction (0..1) of playbacks that hit a simulated fatal player
# error a few seconds in, so New Relic captures real video-player failures
# (kanpachi.hiss + NR Video Agent error). Default 0.2 (~1 in 5). 0 disables.
VITE_PLAYER_CHAOS_ERROR_RATE=0.2
